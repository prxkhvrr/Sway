        { emoji:"<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' width='22' height='22'><path d='M9 17H7A5 5 0 017 7h2M15 7h2a5 5 0 010 10h-2M8 12h8'/></svg>", label:"Requests",         sub:"Handle transfers",  act:"handleReq" },
        { emoji:"<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' width='22' height='22'><circle cx='12' cy='12' r='10'/><path d='M12 8v4m0 4h.01'/></svg>", label:"Add Item",          sub:"Create new SKU",    act:"addItem"   },
        { emoji:"<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' width='22' height='22'><line x1='18' y1='20' x2='18' y2='10'/><line x1='12' y1='20' x2='12' y2='4'/><line x1='6' y1='20' x2='6' y2='14'/></svg>", label:"Insights",          sub:"Analytics & trends", act:"insights"  }
      ]
    };

    document.getElementById("quickActions").innerHTML = actionMap[currentRole]
      .map(a => `
        <div class="action-card" data-act="${a.act}">
          ${a.badge ? `<div class="action-card-badge">${a.badge}</div>` : ""}
          <div class="action-card-icon">${a.emoji}</div>
          <div class="action-card-label">${a.label}</div>
          <div class="action-card-sub">${a.sub}</div>
        </div>`)
      .join("");

    document.querySelectorAll(".action-card").forEach(card => card.addEventListener("click", () => {
      const act = card.dataset.act;
      if (act === "scan")      showToast("Scanner ready (demo)");
      if (act === "checkout")  openCheckoutModal(null);
      if (act === "transfer")  openTransferModal(null);
      if (act === "notif")     showToast("3 notifications: low stock, approval pending");
      if (act === "approvals") switchTabUI("transfers");
      if (act === "manageInv") openManageInventoryModal();
      if (act === "handleReq") switchTabUI("transfers");
      if (act === "addItem")   openAddItemModal();
      if (act === "insights")  switchTabUI("insights");
    }));

    const feedData = [
      { group:"TODAY",     icon:"📦", iconCls:"fi-out",     name:"Safety Gloves XL",     sub:"Checked out by Jordan · WO-2026-0041", tag:"Out",      tagCls:"tag-out",      time:"2h ago" },
      { group:null,        icon:"✅", iconCls:"fi-in",      name:'Torque Wrench 3/8"',   sub:"Received from WH-A12 · 5 units",       tag:"Received", tagCls:"tag-in",       time:"4h ago" },
      { group:null,        icon:"⚠️", iconCls:"fi-alert",   name:"Lubricant Spray 400ml",sub:"Low stock alert · 3 units remaining",   tag:"Critical", tagCls:"tag-critical", time:"5h ago" },
      { group:"YESTERDAY", icon:"→",  iconCls:"fi-pending", name:"M6 Hex Bolt (100pk)",  sub:"Transfer request to WH-B04 · REQ-0318", tag:"Pending",  tagCls:"tag-pending",  time:"Apr 7"  },
    ];

    let html = "";
    feedData.forEach(f => {
      if (f.group) html += `<div class="feed-group-label">${f.group}</div>`;
      html += `
        <div class="feed-item">
          <div class="feed-icon ${f.iconCls}">${f.icon}</div>
          <div class="feed-body">
            <div class="feed-name">${f.name}</div>
            <div class="feed-sub">${f.sub}</div>
          </div>
          <div class="feed-right">
            <div class="status-tag ${f.tagCls}">${f.tag}</div>
            <div class="feed-time">${f.time}</div>
          </div>
        </div>`;
    });

    document.getElementById("activityFeed").innerHTML = html;
  }

  // ── Inventory ──
  function renderInventory() {
    const filter = document.querySelector("#filterChips .fchip.active")?.dataset.filter || "all";
    const search = (document.getElementById("invSearch")?.value || "").toLowerCase();

    let filtered = products.filter(p => p.name.toLowerCase().includes(search) || p.sku.toLowerCase().includes(search));
    if (filter === "low")      filtered = filtered.filter(p => p.stock <= p.low && p.stock > p.crit);
    if (filter === "critical") filtered = filtered.filter(p => p.stock <= p.crit);

    document.getElementById("inventoryList").innerHTML = filtered.map(p => {
      const cls  = p.stock <= p.crit ? "badge-crit" : p.stock <= p.low ? "badge-low" : "badge-ok";
      const warn = p.stock <= p.crit ? `<span class="warn-label">⚠ Only ${p.stock} left</span>` : p.stock <= p.low ? `<span class="warn-label">Low stock</span>` : "";
      const buttons = currentRole !== "admin"
        ? `<button class="sm-btn co-btn" data-id="${p.id}">Checkout</button>
           <button class="sm-btn tr-btn" data-id="${p.id}">Request more</button>`
        : `<button class="sm-btn es-btn" data-id="${p.id}">Edit stock</button>`;
      return `
        <div class="item-row">
          <div class="item-icon">${p.icon}</div>
          <div class="item-info">
            <div class="item-name">${p.name}${warn}</div>
            <div class="item-meta">${p.sku} · Zone ${p.zone} · ${p.cat}</div>
          </div>
          <span class="stock-badge ${cls}">${p.stock} units</span>
          <div class="row-actions">${buttons}</div>
        </div>`;
    }).join("") || `<div style="padding:30px;text-align:center;color:var(--text-3);font-size:13px;">No items found</div>`;

    document.querySelectorAll(".co-btn").forEach(b => b.addEventListener("click", () => openCheckoutModal(products.find(p => p.id == b.dataset.id))));
    document.querySelectorAll(".tr-btn").forEach(b => b.addEventListener("click", () => openTransferModal(products.find(p => p.id == b.dataset.id))));
    document.querySelectorAll(".es-btn").forEach(b => b.addEventListener("click", () => openStockEditModal(products.find(p => p.id == b.dataset.id))));
  }

  // ── Transfers ──
  function renderTransfers() {
    const list = currentRole === "worker" ? transferRequests.filter(r => r.requester === "Jordan D.") : transferRequests;

    document.getElementById("requestsList").innerHTML = list.length ? list.map(r => {
      const pillCls = r.status === "Pending" ? "pill-pending" : r.status === "Approved" ? "pill-approved" : "pill-rejected";
      return `
        <div class="item-row">
          <div class="item-info">
            <div class="item-name">${r.id}</div>
            <div class="item-meta">${r.productName} · ${r.qty} units · ${r.priority} · ${r.date}</div>
          </div>
          <span class="status-pill ${pillCls}">${r.status}</span>
          <div class="row-actions">
            <button class="sm-btn view-req-btn" data-id="${r.id}">Details</button>
          </div>
        </div>`;
    }).join("") : `<div style="padding:30px;text-align:center;color:var(--text-3);font-size:13px;">No transfer requests yet</div>`;

    document.querySelectorAll(".view-req-btn").forEach(b => b.addEventListener("click", () => openRequestDetailModal(transferRequests.find(r => r.id === b.dataset.id))));
  }

  // ── Insights ──
  function renderInsights() {
    document.getElementById("insightsFeed").innerHTML = `
      <div class="feed-item"><div class="feed-icon fi-alert">⚠️</div><div class="feed-body"><div class="feed-name">Lubricant spray — critical stock</div><div class="feed-sub">Only 3 units remaining</div></div><span class="status-tag tag-critical">Urgent</span></div>
      <div class="feed-item"><div class="feed-icon fi-pending">⏱</div><div class="feed-body"><div class="feed-name">Pending approval &gt;24h: REQ-001</div><div class="feed-sub">Awaiting manager review</div></div><span class="status-tag tag-pending">Overdue</span></div>
      <div class="feed-item"><div class="feed-icon fi-in">📈</div><div class="feed-body"><div class="feed-name">Most requested: Lubricant Spray 400ml</div><div class="feed-sub">50 units this week</div></div><span class="status-tag tag-in">Trend</span></div>
      <div class="feed-item"><div class="feed-icon fi-out">👤</div><div class="feed-body"><div class="feed-name">Top requester: Jordan D.</div><div class="feed-sub">4 requests this week</div></div><span class="status-tag tag-out">Info</span></div>
    `;
  }

  // ── Item Picker (shared) ──
  function buildItemPicker(containerId, searchId, selectedCallback, preselected) {
    let selectedProduct = preselected || null;

    function render(query) {
      const q = (query || "").toLowerCase();
      const filtered = products.filter(p => p.name.toLowerCase().includes(q) || p.sku.toLowerCase().includes(q));
      const container = document.getElementById(containerId);
      if (!container) return;

      if (selectedProduct) {
        container.innerHTML = `
          <div class="selected-item-bar">
            <span style="font-size:18px">${selectedProduct.icon}</span>
            <span class="sel-name">${selectedProduct.name} <span style="color:var(--text-3);font-weight:400">${selectedProduct.sku}</span></span>
            <span class="sel-clear" id="clearSel">✕</span>
          </div>`;
        document.getElementById("clearSel")?.addEventListener("click", () => {
          selectedProduct = null;
          render("");
          document.getElementById(searchId).value = "";
          selectedCallback(null);
        });
        selectedCallback(selectedProduct);
        return;
      }

      if (!filtered.length) {
        container.innerHTML = `<div class="item-picker"><div class="no-results">No items found</div></div>`;
        return;
      }

      container.innerHTML = `<div class="item-picker">${
        filtered.map(p => `
          <div class="picker-item" data-id="${p.id}">
            <span class="picker-icon">${p.icon}</span>
            <div>
              <div class="picker-name">${p.name}</div>
              <div class="picker-meta">${p.sku} · Zone ${p.zone}</div>
            </div>
            <span class="picker-stock">${p.stock} units</span>
          </div>`).join("")
      }</div>`;

      container.querySelectorAll(".picker-item").forEach(el => el.addEventListener("click", () => {
        selectedProduct = products.find(p => p.id == el.dataset.id);
        render("");
        selectedCallback(selectedProduct);
      }));
    }

    render("");
    document.getElementById(searchId)?.addEventListener("input", e => render(e.target.value));
    return { getSelected: () => selectedProduct };
  }

  // ── Modals ──
  function openCheckoutModal(preselected) {
    let qty = 1;
    let selectedProduct = preselected;

    openModal(`
      <div class="modal-head">
        <div class="modal-title">Checkout item</div>
        <button class="close-btn">×</button>
      </div>
      <div class="form-group">
        <label class="form-label">Search item</label>
        <div class="modal-search-wrap">
          <span class="modal-search-icon">🔍</span>
          <input class="modal-search-input" id="coSearch" placeholder="Search by name or SKU…" ${preselected ? 'style="display:none"':''}>
        </div>
        <div id="coPickerContainer"></div>
      </div>
      <div id="coDetails" style="${!preselected?'display:none':''}">
        <div class="form-group">
          <label class="form-label">Quantity</label>
          <div class="stepper">
            <button class="step-btn" id="decQ">−</button>
            <span class="step-val" id="qtyVal">1</span>
            <button class="step-btn" id="incQ">+</button>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Work order</label>
          <input class="form-input" id="wo" value="WO-2026-0041">
        </div>
        <div class="form-group">
          <label class="form-label">Expected return</label>
          <input class="form-input" type="date" id="retDate">
        </div>
        <button class="cta-btn" id="confirmCheckout">Confirm checkout</button>
      </div>
    `);

    const updQty = () => document.getElementById("qtyVal").textContent = qty;

    const showDetails = (p) => {
      selectedProduct = p;
      const det = document.getElementById("coDetails");
      const srch = document.getElementById("coSearch");
      if (p) {
        det.style.display = "";
        if (srch) srch.style.display = "none";
        qty = 1; updQty();
      } else {
        det.style.display = "none";
        if (srch) srch.style.display = "";
      }
    };

    buildItemPicker("coPickerContainer", "coSearch", showDetails, preselected);
    if (preselected) showDetails(preselected);

    document.getElementById("decQ")?.addEventListener("click", () => { if (qty > 1) qty--; updQty(); });
    document.getElementById("incQ")?.addEventListener("click", () => { if (selectedProduct && qty < selectedProduct.stock) qty++; updQty(); });
    document.getElementById("confirmCheckout")?.addEventListener("click", () => {
      if (!selectedProduct) return;
      selectedProduct.stock -= qty;
      showToast(`Checked out ${qty} × ${selectedProduct.name}`);
      renderInventory(); renderDashboard(); closeModal();
    });
  }

  function openTransferModal(preselected) {
    let qty = 10;
    let priority = "High";
    let selectedProduct = preselected;

    openModal(`
      <div class="modal-head">
        <div class="modal-title">Transfer request</div>
        <button class="close-btn">×</button>
      </div>
      <div class="form-group">
        <label class="form-label">Search item</label>
