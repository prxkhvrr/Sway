      <div id="trDetails" style="${!preselected?'display:none':''}">
        <div id="trLowWarn" style="display:none;font-size:12px;color:var(--warn);margin-bottom:14px;">⚠ Stock is low — consider urgent priority</div>
        <div class="form-group">
          <label class="form-label">Quantity needed</label>
          <div class="stepper">
            <button class="step-btn" id="decT">−</button>
            <span class="step-val" id="qtyT">10</span>
            <button class="step-btn" id="incT">+</button>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Priority</label>
          <div class="prio-group" id="prioGroup">
            <button class="prio-pill" data-p="Low">Low</button>
            <button class="prio-pill" data-p="Med">Med</button>
            <button class="prio-pill active" data-p="High">High</button>
            <button class="prio-pill" data-p="Urgent">Urgent</button>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Reason</label>
          <textarea class="form-input" id="reason" rows="2">Production resupply</textarea>
        </div>
        <button class="cta-btn" id="submitTransfer">Submit request</button>
      </div>
    `);

    const updQty = () => document.getElementById("qtyT").textContent = qty;

    const showDetails = (p) => {
      selectedProduct = p;
      const det = document.getElementById("trDetails");
      const srch = document.getElementById("trSearch");
      if (p) {
        det.style.display = "";
        if (srch) srch.style.display = "none";
        const warn = document.getElementById("trLowWarn");
        if (warn) warn.style.display = p.stock <= p.low ? "" : "none";
        qty = 10; updQty();
      } else {
        det.style.display = "none";
        if (srch) srch.style.display = "";
      }
    };

    buildItemPicker("trPickerContainer", "trSearch", showDetails, preselected);
    if (preselected) showDetails(preselected);

    document.getElementById("decT")?.addEventListener("click", () => { if (qty > 1) qty--; updQty(); });
    document.getElementById("incT")?.addEventListener("click", () => { qty++; updQty(); });
    document.querySelectorAll("#prioGroup .prio-pill").forEach(b => b.addEventListener("click", () => {
      document.querySelectorAll("#prioGroup .prio-pill").forEach(x => x.classList.remove("active"));
      b.classList.add("active"); priority = b.dataset.p;
    }));
    document.getElementById("submitTransfer")?.addEventListener("click", () => {
      if (!selectedProduct) { showToast("Please select an item first"); return; }
      const req = {
        id: `REQ-${String(transferRequests.length + 1).padStart(3,"0")}`,
        productName: selectedProduct.name,
        qty, priority,
        status: "Pending",
        date: new Date().toLocaleDateString("en-US", { month:"short", day:"numeric" }),
        requester: "Jordan D.",
        destinationWH: "WH-B04",
        productId: selectedProduct.id
      };
      transferRequests.unshift(req);
      showToast(`Request ${req.id} submitted`);
      renderTransfers(); renderDashboard(); closeModal();
    });
  }

  function openStockEditModal(prod) {
    openModal(`
      <div class="modal-head">
        <div class="modal-title">Adjust stock · ${prod.name}</div>
        <button class="close-btn">×</button>
      </div>
      <div class="form-group">
        <label class="form-label">Current stock: ${prod.stock}</label>
        <input class="form-input" type="number" id="newStockVal" value="${prod.stock}">
      </div>
      <button class="cta-btn" id="saveStock">Update stock</button>
    `);
    document.getElementById("saveStock").onclick = () => {
      const v = parseInt(document.getElementById("newStockVal").value);
      if (!isNaN(v)) { prod.stock = v; showToast(`${prod.name} updated to ${v}`); renderInventory(); renderDashboard(); closeModal(); }
    };
  }

  function openAddItemModal() {
    openModal(`
      <div class="modal-head">
        <div class="modal-title">Add new item</div>
        <button class="close-btn">×</button>
      </div>
      <div class="form-group"><label class="form-label">Name</label><input class="form-input" id="newName" placeholder="e.g. Safety Mask"></div>
      <div class="form-group"><label class="form-label">SKU</label><input class="form-input" id="newSku" placeholder="SKU-xxxxx"></div>
      <div class="form-group"><label class="form-label">Initial stock</label><input class="form-input" type="number" id="newStock" value="0"></div>
      <div class="form-group"><label class="form-label">Category</label><input class="form-input" id="newCat" placeholder="PPE"></div>
      <button class="cta-btn" id="createItem">Create item</button>
    `);
    document.getElementById("createItem").onclick = () => {
      const name = document.getElementById("newName").value;
      if (!name) return;
      products.push({ id: products.length+1, name, sku: document.getElementById("newSku").value||"SKU-NEW", stock: parseInt(document.getElementById("newStock").value)||0, zone:"NEW", icon:"📦", low:10, crit:2, cat: document.getElementById("newCat").value });
      showToast(`${name} added`);
      renderInventory(); renderDashboard(); closeModal();
    };
  }

  function openManageInventoryModal() {
    openModal(`
      <div class="modal-head">
        <div class="modal-title">Manage inventory</div>
        <button class="close-btn">×</button>
      </div>
      ${products.map(p => `<div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border);font-size:13px;"><div><div style="font-weight:600">${p.name}</div><div style="color:var(--text-3);font-size:12px">${p.stock} units</div></div><button class="sm-btn adj-btn" data-id="${p.id}">Adjust</button></div>`).join("")}
      <button class="cta-btn" style="margin-top:16px;" id="closeManage">Close</button>
    `);
    document.querySelectorAll(".adj-btn").forEach(b => b.onclick = () => openStockEditModal(products.find(p => p.id == b.dataset.id)));
    document.getElementById("closeManage").onclick = closeModal;
  }

  function openRequestDetailModal(req) {
    const canApprove = (currentRole === "manager" || currentRole === "admin") && req.status === "Pending";
    openModal(`
      <div class="modal-head">
        <div class="modal-title">${req.id} · ${req.productName}</div>
        <button class="close-btn">×</button>
      </div>
      <p style="font-size:13px;color:var(--text-2);margin-bottom:4px;"><strong style="color:var(--text)">${req.qty} units</strong> · Priority: ${req.priority}</p>
      <p style="font-size:12px;color:var(--text-3);margin-bottom:8px;">Requester: ${req.requester} · ${req.date}</p>
      <div class="timeline">
        <div class="t-step"><div class="t-dot done">✓</div>Submitted</div>
        <div class="t-step"><div class="t-dot ${req.status!=='Pending'?'done':'cur'}">${req.status==='Approved'?'✓':'●'}</div>Review</div>
        <div class="t-step"><div class="t-dot ${req.status==='Approved'?'done':''}">${req.status==='Approved'?'✓':'○'}</div>Completed</div>
      </div>
      ${canApprove ? `
        <div class="form-group">
          <label class="form-label">Source warehouse</label>
          <select class="form-input" id="srcSelect">
            <option>WH-A12 (184 available)</option>
            <option>WH-F02 (92 available)</option>
          </select>
        </div>
        <div class="modal-btn-row">
          <button class="cta-btn success" id="approveBtn">Approve &amp; ship</button>
          <button class="cta-btn danger"  id="rejectBtn">Reject</button>
        </div>
      ` : `<button class="cta-btn" id="closeDetail">Close</button>`}
    `);
    if (canApprove) {
      document.getElementById("approveBtn").onclick = () => { req.status = "Approved"; showToast(`${req.id} approved`); renderTransfers(); renderDashboard(); closeModal(); };
      document.getElementById("rejectBtn").onclick  = () => { req.status = "Rejected"; showToast(`${req.id} rejected`); renderTransfers(); renderDashboard(); closeModal(); };
    } else {
      document.getElementById("closeDetail")?.addEventListener("click", closeModal);
    }
  }

  // ── Tab switching ──
  function switchTab(tabId) {
    document.querySelectorAll(".screen").forEach(s => s.classList.remove("active"));
    document.getElementById(tabId + "Screen").classList.add("active");
    if (tabId === "inventory") renderInventory();
    if (tabId === "transfers") renderTransfers();
    if (tabId === "dashboard") renderDashboard();
    if (tabId === "insights")  renderInsights();
  }

  function switchTabUI(tabId) {
    document.querySelectorAll(".tab").forEach(t => t.classList.toggle("active", t.dataset.tab === tabId));
    switchTab(tabId);
  }

  // ── Event wiring ──
  document.querySelectorAll(".tab").forEach(t => t.addEventListener("click", () => {
    document.querySelectorAll(".tab").forEach(x => x.classList.remove("active"));
    t.classList.add("active");
    switchTab(t.dataset.tab);
  }));

  document.querySelectorAll(".role-btn").forEach(r => r.addEventListener("click", () => {
    currentRole = r.dataset.role;
    updateRoleUI();
    const activeTab = document.querySelector(".tab.active")?.dataset.tab || "dashboard";
    if (activeTab === "insights" && currentRole !== "admin") {
      switchTabUI("dashboard");
    }
  }));

  document.getElementById("filterChips").innerHTML = `
    <button class="fchip active" data-filter="all">All</button>
    <button class="fchip" data-filter="low">Low stock</button>
    <button class="fchip" data-filter="critical">Critical</button>
  `;

  document.querySelectorAll("#filterChips .fchip").forEach(c => c.addEventListener("click", function() {
    document.querySelectorAll("#filterChips .fchip").forEach(x => x.classList.remove("active"));
    this.classList.add("active");
    renderInventory();
  }));

  document.getElementById("invSearch").addEventListener("input", renderInventory);
  document.getElementById("newTransferGlobal").addEventListener("click", () => openTransferModal(null));

  // ── Init ──
  updateRoleUI();
</script>
</body>
</html>
