<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title>Stockflow · Inventory Management</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #ECEEF2;
      --surface: #FFFFFF;
      --border: #E2E6ED;
      --border-strong: #C8CDD8;
      --text: #111827;
      --text-2: #6B7280;
      --text-3: #9CA3AF;
      --accent: #111827;
      --accent-mid: #374151;
      --accent-bg: #F3F4F6;
      --accent-text: #111827;
      --danger: #DC2626;
      --danger-bg: #FEF2F2;
      --warn: #D97706;
      --warn-bg: #FFFBEB;
      --success: #059669;
      --success-bg: #ECFDF5;
      --radius-sm: 10px;
      --radius: 14px;
      --radius-lg: 18px;
      --radius-xl: 24px;
      --radius-pill: 999px;
      --shadow-sm: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
      --shadow: 0 4px 16px rgba(0,0,0,0.08);
      --shadow-lg: 0 8px 32px rgba(0,0,0,0.12);
    }

    body {
      font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      color: var(--text);
      font-size: 14px;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }

    /* ── Layout ── */
    .app {
      max-width: 1100px;
      margin: 0 auto;
      padding: 20px 20px;
    }

    /* ── Header ── */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
      flex-wrap: wrap;
      gap: 12px;
    }

    .header-left { display: flex; align-items: center; gap: 14px; }

    .menu-btn {
      width: 42px; height: 42px;
      border-radius: var(--radius-sm);
      background: var(--accent);
      border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }

    .menu-btn svg { width: 18px; height: 18px; color: #fff; }

    .brand-name {
      font-size: 20px;
      font-weight: 700;
      letter-spacing: -0.5px;
      color: var(--text);
    }

    .header-right { display: flex; align-items: center; gap: 12px; }

    .role-selector {
      display: flex;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-pill);
      padding: 3px;
      gap: 2px;
      box-shadow: var(--shadow-sm);
    }

    .role-btn {
      padding: 6px 16px;
      border-radius: var(--radius-pill);
      border: none;
      background: transparent;
      font-family: inherit;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      color: var(--text-2);
      transition: background .14s, color .14s;
    }

    .role-btn.active { background: var(--accent); color: #fff; }

    .user-chip {
      display: flex;
      align-items: center;
      gap: 10px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-pill);
      padding: 5px 14px 5px 5px;
      box-shadow: var(--shadow-sm);
    }

    .user-avatar {
      width: 34px; height: 34px;
      border-radius: 50%;
      background: var(--accent);
      color: #fff;
      font-size: 12px;
      font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }

    .user-info { line-height: 1.3; }
    .user-name { font-size: 13px; font-weight: 600; color: var(--text); }
    .user-sub  { font-size: 11px; color: var(--text-3); }

    /* ── Tabs ── */
    .tabs {
      display: flex;
      gap: 4px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-pill);
      padding: 4px;
      width: fit-content;
      margin-bottom: 28px;
      box-shadow: var(--shadow-sm);
    }

    .tab {
      padding: 8px 26px;
      border-radius: var(--radius-pill);
      border: none;
      background: transparent;
      font-family: inherit;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      color: var(--text-2);
      transition: background .14s, color .14s;
    }

    .tab.active { background: var(--accent); color: #fff; }

    /* ── Screens ── */
    .screen { display: none; animation: fadeUp .18s ease both; }
    .screen.active { display: block; }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(6px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Dashboard greeting ── */
    .dash-greeting {
      margin-bottom: 26px;
    }

    .dash-greeting h1 {
      font-size: 26px;
      font-weight: 700;
      letter-spacing: -0.5px;
      color: var(--text);
      line-height: 1.2;
    }

    .dash-greeting p {
      font-size: 14px;
      color: var(--text-2);
      margin-top: 4px;
    }

    /* ── Quick action cards ── */
    .action-cards {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
      margin-bottom: 32px;
    }

    .action-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 20px 16px;
      cursor: pointer;
      text-align: center;
      position: relative;
      transition: border-color .14s, box-shadow .14s, transform .14s;
      box-shadow: var(--shadow-sm);
    }

    .action-card:hover {
      border-color: var(--border-strong);
      box-shadow: var(--shadow);
      transform: translateY(-1px);
    }

    .action-card-icon {
      width: 48px; height: 48px;
      background: var(--bg);
      border-radius: var(--radius-sm);
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 12px;
      font-size: 20px;
    }

    .action-card-label {
      font-size: 14px;
      font-weight: 600;
      color: var(--text);
      line-height: 1.3;
    }

    .action-card-sub {
      font-size: 12px;
      color: var(--text-3);
      margin-top: 3px;
    }

    .action-card-badge {
      position: absolute;
      top: 10px; right: 10px;
      background: var(--danger);
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      width: 20px; height: 20px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
    }

    /* ── Section header ── */
    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 14px;
    }

    .section-title {
      font-size: 16px;
      font-weight: 700;
      color: var(--text);
      letter-spacing: -0.2px;
    }

    .view-all-btn {
      font-size: 13px;
      font-weight: 500;
      color: var(--text-2);
      background: none;
      border: none;
      cursor: pointer;
      display: flex; align-items: center; gap: 4px;
      transition: color .12s;
    }

    .view-all-btn:hover { color: var(--text); }

    /* ── Activity feed ── */
    .feed {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      overflow: hidden;
      box-shadow: var(--shadow-sm);
    }

    .feed-group-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .7px;
      text-transform: uppercase;
      color: var(--text-3);
      padding: 12px 16px 8px;
    }

    .feed-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 13px 16px;
      border-top: 1px solid var(--border);
      transition: background .1s;
      cursor: default;
    }

    .feed-item:hover { background: var(--bg); }

    .feed-icon {
      width: 36px; height: 36px;
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 15px;
      flex-shrink: 0;
    }

    .fi-out    { background: #F3F4F6; }
    .fi-in     { background: var(--success-bg); }
    .fi-alert  { background: var(--danger-bg); }
    .fi-pending { background: var(--warn-bg); }

    .feed-body  { flex: 1; }
    .feed-name  { font-size: 13px; font-weight: 600; color: var(--text); }
    .feed-sub   { font-size: 12px; color: var(--text-3); margin-top: 1px; }
    .feed-right { text-align: right; flex-shrink: 0; }
    .feed-time  { font-size: 12px; color: var(--text-3); }

    .status-tag {
      display: inline-block;
      font-size: 11px;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: var(--radius-pill);
      margin-bottom: 2px;
    }

    .tag-out     { background: #F3F4F6; color: #374151; }
    .tag-in      { background: var(--success-bg); color: var(--success); }
    .tag-critical{ background: var(--danger-bg);  color: var(--danger); }
    .tag-pending { background: var(--warn-bg);    color: var(--warn); }

    /* ── Section labels ── */
    .section-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .7px;
      text-transform: uppercase;
      color: var(--text-3);
      margin-bottom: 10px;
    }

    /* ── Inventory ── */
    .search-row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 16px;
      align-items: center;
    }

    .search-input {
      flex: 1;
      min-width: 200px;
      padding: 9px 16px;
      border-radius: var(--radius-pill);
      border: 1px solid var(--border);
      background: var(--surface);
      font-family: inherit;
      font-size: 13px;
      color: var(--text);
      box-shadow: var(--shadow-sm);
      outline: none;
      transition: border-color .12s;
    }

    .search-input:focus { border-color: var(--accent); }

    .filter-chips { display: flex; gap: 6px; flex-wrap: wrap; }

    .fchip {
      padding: 7px 16px;
      border-radius: var(--radius-pill);
      border: 1px solid var(--border);
      background: var(--surface);
      font-family: inherit;
      font-size: 12px;
      font-weight: 500;
      cursor: pointer;
      color: var(--text-2);
      transition: background .1s, color .1s, border-color .1s;
    }

    .fchip.active { background: var(--accent); color: #fff; border-color: var(--accent); }

    /* ── Item rows ── */
    .item-list { display: flex; flex-direction: column; gap: 8px; }

    .item-row {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 14px 16px;
      display: flex;
      align-items: center;
      gap: 14px;
      flex-wrap: wrap;
      box-shadow: var(--shadow-sm);
      transition: border-color .12s;
    }

    .item-row:hover { border-color: var(--border-strong); }

    .item-icon {
      width: 40px; height: 40px;
      border-radius: var(--radius-sm);
      background: var(--bg);
      display: flex; align-items: center; justify-content: center;
      font-size: 18px;
      flex-shrink: 0;
    }

    .item-info { flex: 1; min-width: 130px; }
    .item-name { font-weight: 600; font-size: 14px; color: var(--text); }
    .item-meta { font-size: 12px; color: var(--text-3); margin-top: 2px; }

    .warn-label {
      display: inline-block;
      font-size: 11px;
      font-weight: 600;
      color: var(--danger);
      margin-left: 6px;
    }

    .stock-badge {
      font-size: 12px;
      font-weight: 600;
      padding: 4px 11px;
      border-radius: var(--radius-pill);
      white-space: nowrap;
    }

    .badge-ok   { background: var(--success-bg); color: var(--success); }
    .badge-low  { background: var(--warn-bg);    color: var(--warn); }
    .badge-crit { background: var(--danger-bg);  color: var(--danger); }

    .row-actions { display: flex; gap: 6px; flex-shrink: 0; }

    .sm-btn {
      padding: 7px 15px;
      border-radius: var(--radius-pill);
      border: 1px solid var(--border);
      background: var(--surface);
      font-family: inherit;
      font-size: 12px;
      font-weight: 500;
      cursor: pointer;
      color: var(--text);
      transition: background .1s, color .1s, border-color .1s;
      white-space: nowrap;
    }

    .sm-btn:hover { background: var(--accent); color: #fff; border-color: var(--accent); }
    .sm-btn.primary { background: var(--accent); color: #fff; border-color: var(--accent); }

    /* ── Transfers ── */
    .transfers-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 16px;
    }

    /* ── Modal ── */
    .overlay {
      position: fixed;
      inset: 0;
      background: rgba(10, 20, 40, .45);
      backdrop-filter: blur(3px);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 100;
      opacity: 0;
      pointer-events: none;
      transition: opacity .2s;
    }

    .overlay.open { opacity: 1; pointer-events: all; }

    .modal {
      background: var(--surface);
      border-radius: var(--radius-xl);
      padding: 24px;
      width: 90%;
      max-width: 500px;
      border: 1px solid var(--border);
      box-shadow: var(--shadow-lg);
      animation: fadeUp .18s ease both;
      max-height: 90vh;
      overflow-y: auto;
    }

    .modal-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 20px;
      gap: 10px;
    }

    .modal-title {
      font-size: 16px;
      font-weight: 700;
      line-height: 1.3;
      letter-spacing: -0.2px;
    }

    .close-btn {
      width: 30px; height: 30px; min-width: 30px;
      border-radius: 50%;
      border: 1px solid var(--border);
      background: transparent;
      cursor: pointer;
      font-size: 16px;
      color: var(--text-2);
      display: flex; align-items: center; justify-content: center;
      transition: background .1s;
    }

    .close-btn:hover { background: var(--bg); }

    /* ── Modal item search ── */
    .modal-search-wrap {
      position: relative;
      margin-bottom: 16px;
    }

    .modal-search-input {
      width: 100%;
      padding: 9px 14px 9px 36px;
      border-radius: var(--radius-sm);
      border: 1px solid var(--border);
      font-family: inherit;
      font-size: 13px;
      color: var(--text);
      background: var(--bg);
      outline: none;
      transition: border-color .12s;
    }

    .modal-search-input:focus { border-color: var(--accent); background: var(--surface); }

    .modal-search-icon {
      position: absolute;
      left: 12px; top: 50%;
      transform: translateY(-50%);
      color: var(--text-3);
      font-size: 14px;
      pointer-events: none;
    }

    .item-picker {
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      overflow: hidden;
      margin-bottom: 16px;
      max-height: 200px;
      overflow-y: auto;
    }

    .picker-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 12px;
      cursor: pointer;
      border-bottom: 1px solid var(--border);
      transition: background .1s;
    }

    .picker-item:last-child { border-bottom: none; }
    .picker-item:hover { background: var(--bg); }
    .picker-item.selected { background: var(--accent-bg); }

    .picker-icon { font-size: 16px; flex-shrink: 0; }
    .picker-name { font-size: 13px; font-weight: 600; color: var(--text); }
    .picker-meta { font-size: 11px; color: var(--text-3); }
    .picker-stock { margin-left: auto; font-size: 12px; font-weight: 600; color: var(--text-2); flex-shrink: 0; }

    .selected-item-bar {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 10px 14px;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 13px;
    }

    .selected-item-bar .sel-name { font-weight: 600; flex: 1; }
    .selected-item-bar .sel-clear { cursor: pointer; color: var(--text-3); font-size: 16px; line-height: 1; }
    .selected-item-bar .sel-clear:hover { color: var(--danger); }

    .no-results {
      padding: 20px;
      text-align: center;
      color: var(--text-3);
      font-size: 13px;
    }

    .form-group { margin-bottom: 16px; }

    .form-label {
      display: block;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .5px;
      text-transform: uppercase;
      color: var(--text-2);
      margin-bottom: 6px;
    }

    .form-input {
      width: 100%;
      padding: 9px 14px;
      border-radius: var(--radius-sm);
      border: 1px solid var(--border);
      font-family: inherit;
      font-size: 13px;
      color: var(--text);
      background: var(--surface);
      outline: none;
      transition: border-color .12s;
    }

    .form-input:focus { border-color: var(--accent); }

    .prio-group { display: flex; gap: 6px; }

    .prio-pill {
      flex: 1;
      padding: 8px 6px;
      border: 1px solid var(--border);
      border-radius: var(--radius-pill);
      background: var(--surface);
      font-family: inherit;
      font-size: 12px;
      font-weight: 500;
      cursor: pointer;
      text-align: center;
      color: var(--text-2);
      transition: background .1s, color .1s, border-color .1s;
    }

    .prio-pill.active { background: var(--accent); color: #fff; border-color: var(--accent); }

    .stepper { display: flex; align-items: center; gap: 12px; }

    .step-btn {
      width: 32px; height: 32px;
      border-radius: 50%;
      border: 1px solid var(--border);
      background: var(--surface);
      cursor: pointer;
      font-size: 18px;
      color: var(--text);
      display: flex; align-items: center; justify-content: center;
      transition: background .1s;
    }

    .step-btn:hover { background: var(--bg); }
    .step-val { min-width: 32px; text-align: center; font-weight: 600; font-size: 15px; }

    .cta-btn {
      width: 100%;
      padding: 12px;
      border-radius: var(--radius-pill);
      border: none;
      background: var(--accent);
      color: #fff;
      font-family: inherit;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      margin-top: 4px;
      transition: opacity .12s;
    }

    .cta-btn:hover { opacity: 0.85; }
    .cta-btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .cta-btn.danger  { background: var(--danger); }
    .cta-btn.success { background: var(--success); }

    .modal-btn-row {
      display: flex;
      gap: 8px;
      margin-top: 4px;
    }

    .modal-btn-row .cta-btn { margin-top: 0; }

    /* ── Timeline ── */
    .timeline {
      display: flex;
      justify-content: space-between;
      margin: 20px 0;
      position: relative;
    }

    .timeline::before {
      content: '';
      position: absolute;
      top: 14px;
      left: 12%; right: 12%;
      height: 1px;
      background: var(--border);
      z-index: 0;
    }

    .t-step {
      flex: 1;
      text-align: center;
      font-size: 11px;
      color: var(--text-3);
      position: relative;
      z-index: 1;
    }

    .t-dot {
      width: 28px; height: 28px;
      border-radius: 50%;
      background: var(--surface);
      border: 2px solid var(--border-strong);
      margin: 0 auto 6px;
      display: flex; align-items: center; justify-content: center;
      font-size: 11px;
      color: var(--text-3);
    }

    .t-dot.done { background: var(--success); border-color: var(--success); color: #fff; }
    .t-dot.cur  { border-color: var(--accent); color: var(--accent); }

    /* ── Status pills ── */
    .status-pill {
      font-size: 11px;
      font-weight: 600;
      padding: 4px 11px;
      border-radius: var(--radius-pill);
    }

    .pill-pending  { background: var(--warn-bg);    color: var(--warn); }
    .pill-approved { background: var(--success-bg); color: var(--success); }
    .pill-rejected { background: var(--danger-bg);  color: var(--danger); }

    /* ── Toast ── */
    .toast {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%);
      background: #1F2937;
      color: #fff;
      padding: 10px 24px;
      border-radius: var(--radius-pill);
      font-size: 13px;
      font-weight: 500;
      z-index: 200;
      display: none;
      box-shadow: var(--shadow-lg);
      white-space: nowrap;
    }

    /* ── Insights ── */
    #insightsFeed .feed-item:first-child { border-top: none; }

    @media (max-width: 700px) {
      .app { padding: 14px 14px; }
      .action-cards { grid-template-columns: repeat(2, 1fr); }
      .item-row { gap: 10px; }
      .user-chip { display: none; }
    }

    @media (max-width: 400px) {
      .action-cards { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</head>
<body>
<div class="app">

  <!-- Header -->
  <div class="header">
    <div class="header-left">
      <button class="menu-btn" onclick="showToast('Menu (demo)')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
      <span class="brand-name">Stockflow</span>
    </div>
    <div class="header-right">
      <div class="role-selector" id="roles">
